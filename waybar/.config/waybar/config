{
  "layer": "top",
  "position": "top",
  "margin-bottom": -8,
  "spacing" : 0,

  
  "modules-left": [
  "hyprland/workspaces",
  "custom/uptime",
  "cpu"
  ],

  

  "modules-right": [
  	"bluetooth",
    "custom/vpn",
    
    "network",
    "pulseaudio", 
    "backlight",
    "battery",
    "clock"
  ],

  "hyprland/workspaces": {
    "format": " {icon}",
    "format-icons": {
      "active": "´äæ",
      "default": "´åÆ"
    }
  },

  "custom/vpn": {
      "format": "{}",
      "interval": 3,
      "return-type": "json",
      "exec": "$HOME/.config/waybar/check-vpn-status.sh",
      "on-click": "$HOME/.config/waybar/toggle-vpn.sh",
      "on-click-right": "kitty -e $HOME/.config/waybar/select.sh",
      "signal": 8
  },

  "bluetooth": {
    "format": "¾░é▓",
    "format-on": "{icon}",
    "format-off": "{icon}",
    "format-connected":"{icon}",
    "format-icons":{
        "on":"¾░é»",
        "off": "¾░é▓",
        "connected": "¾░é▒",
        },
    "on-click": "blueman-manager",
    "tooltip-format-connected":"{device_enumerate}"
  },

  "custom/music": {
    "format": "´Çü  {}",
    "escape": true,
    "interval": 5,
    "tooltip": false,
    "exec": "playerctl metadata --format='{{ artist }} - {{ title }}'",
    "on-click": "playerctl play-pause",
    "max-length": 50
  },

  "clock": {
    "timezone": "America/New_York",
    "tooltip": false,
    "format": "{:%I:%M - %D}",
    "interval": 60
  },

  "network": {
    "interface": "wlp61s0",
    "format-wifi": "¾░ñó",
    "format-ethernet": "¾░êÇ ",
    "format-disconnected": "¾░ñá ",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "nm-connection-editor"

 },

  "cpu": {
    "interval": 1,
    "format": "´ïø  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"],
    "on-click": "ghostty -e htop"
  },

  "memory": {
    "interval": 30,
    "format": "¯┐à  {used:0.1f}G/{total:0.1f}G",
    "tooltip-format": "Memory"
  },

  "custom/uptime": {
    "format": "{}",
    "format-icon": ["´üó"], 
    "tooltip": false,
    "interval": 1600,
    "exec": "$HOME/.config/waybar/scripts/uptime.sh"
  },
  
  "backlight": {
        "format": "{icon}",
        "format-icons": ["¯Äì","¾░â£", "¾░âø", "¾░â×","¾░âØ","¾░âƒ","¾░âá"],
