        "on-click-middle": "~/.config/waybar/scripts/toggle-hyprsunset.sh"
  },
  
  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "´æª",
    "format-icons": {
      "default": ["´Çª", "´Çº", "´Ç¿ "]
    },
    "on-click": "pavucontrol",
    "max-volume": 150,
    "tooltip-format": "{desc} - {volume}%"
  },

  "battery": {
        "interval":2,
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "´çª {capacity}%",
        "format-plugged": "´çª {capacity}%",
        "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
